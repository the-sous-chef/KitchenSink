{
    "name": "kitchensink",
    "type": "module",
    "private": true,
    "repository": {
        "type": "git",
        "url": "git+https://github.com/the-sous-chef/KitchenSink.git"
    },
    "homepage": "https://github.com/the-sous-chef/KitchenSink#readme",
    "bugs": {
        "url": "https://github.com/the-sous-chef/KitchenSink/issues"
    },
    "packageManager": "npm@11.11.0",
    "engines": {
        "node": ">=24.16.0"
    },
    "workspaces": [
        "packages/tools/*",
        "packages/services/*",
        "packages/shared/*",
        "packages/infra/*",
        "packages/apps/commise/web",
        "packages/apps/commise/mobile",
        "packages/ui"
    ],
    "scripts": {
        "build": "turbo run build",
        "test": "turbo run test",
        "test:e2e": "turbo run test:e2e",
        "lint": "turbo run lint format:check",
        "typecheck": "turbo run typecheck",
        "dev:local": "turbo run dev:local --filter=@kitchensink/identity-service",
        "format": "turbo run format",
        "format:check": "turbo run format:check",
        "prepare": "husky || true"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.8.1",
        "@commitlint/config-conventional": "^19.8.1",
        "@eslint/js": "^10.0.0",
        "eslint": "^10.0.3",
        "eslint-plugin-import-x": "^4.0.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.3.2",
        "turbo": "^2.0.0",
        "typescript-eslint": "^8.56.0"
    },
    "peerDependencies": {
        "typescript": "^5"
    }
}
