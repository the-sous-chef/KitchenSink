{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"]
        },
        "build-ui": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"]
        },
        "test": {
            "outputs": []
        },
        "test:e2e": {
            "dependsOn": ["^build"],
            "outputs": []
        },
        "lint": {
            "outputs": []
        },
        "typecheck": {
            "dependsOn": ["^build"],
            "outputs": []
        },
        "format": {
            "outputs": []
        },
        "format:check": {
            "outputs": []
        },
        "dev:local": {
            "cache": false,
            "persistent": true,
            "outputs": []
        },
        "synth": {
            "dependsOn": ["^build"],
            "outputs": []
        }
    }
}
