{
    "extends": "@kitchensink/typescript/base.json",
    "compilerOptions": {
        "jsx": "react-native",
        "strict": true,
        "moduleResolution": "bundler",
        "module": "ESNext",
        "target": "ESNext",
        "skipLibCheck": true,
        "lib": ["ESNext", "DOM"],
        "noEmit": true,
        "incremental": true,
        "paths": {
            "@kitchensink/identity-service": ["../../services/identity/src/index.ts"],
            "@kitchensink/identity-service/*": ["../../services/identity/src/*"]
        }
    },
    "include": ["src/**/*", "app/**/*", "tests/**/*", "App.tsx", "tamagui.config.ts"],
    "exclude": ["node_modules", "dist"]
}
