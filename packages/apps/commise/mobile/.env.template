# Commise Mobile — Expo environment variables
# Copy this file to `.env.local` and fill in your values.

# ------------------------------------------------------------------------------
# Required — Clerk / IDP authentication
# ------------------------------------------------------------------------------
EXPO_PUBLIC_IDP_PUBLISHABLE_KEY=pk_test_your-publishable-key

# ------------------------------------------------------------------------------
# Required — API backend
# ------------------------------------------------------------------------------
EXPO_PUBLIC_API_URL=https://api.commise.io

# ------------------------------------------------------------------------------
# Required — Clerk authentication
# ------------------------------------------------------------------------------
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key
CLERK_SECRET_KEY=sk_test_your-secret-key

# ------------------------------------------------------------------------------
# Required — API backend
# ------------------------------------------------------------------------------
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

# ------------------------------------------------------------------------------
# Optional — Webhook verification (only needed if running Clerk webhooks locally)
# ------------------------------------------------------------------------------
# CLERK_WEBHOOK_SECRET=whsec_your-webhook-secret

# ------------------------------------------------------------------------------
# Optional — Clerk routing (defaults shown)
# ------------------------------------------------------------------------------
# EXPO_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# EXPOPUBLIC_CLERK_SIGN_UP_URL=/sign-up
# EXPO_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/profile
# EXPO_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/profile

# Sentry
# Client-side DSN (exposed to browser via EXPO_PUBLIC_ prefix)
EXPO_PUBLIC_SENTRY_DSN=

SENTRY_DSN=
SENTRY_ORG=radicle-co
SENTRY_PROJECT=commise-mobile

# Source map upload credentials (only needed in CI/deployment)
SENTRY_AUTH_TOKEN=
