# Commise Mobile — Expo environment variables
# Copy this file to `.env.local` and fill in your values.

# ------------------------------------------------------------------------------
# Required — Clerk authentication
# ------------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key
CLERK_SECRET_KEY=sk_test_your-secret-key

# ------------------------------------------------------------------------------
# Required — API backend
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

# ------------------------------------------------------------------------------
# Optional — Webhook verification (only needed if running Clerk webhooks locally)
# ------------------------------------------------------------------------------
# CLERK_WEBHOOK_SECRET=whsec_your-webhook-secret

# ------------------------------------------------------------------------------
# Optional — Clerk routing (defaults shown)
# ------------------------------------------------------------------------------
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/profile
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/profile

# Sentry
# Client-side DSN (exposed to browser via NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SENTRY_DSN=

SENTRY_DSN=
SENTRY_ORG=radicle-co
SENTRY_PROJECT=commise-web

# Source map upload credentials (only needed in CI/deployment)
SENTRY_AUTH_TOKEN=
