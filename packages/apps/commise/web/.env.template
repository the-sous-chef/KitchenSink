# Commise Web — Next.js environment variables
# Copy this file to `.env.local` and fill in your values.
# Or run `node scripts/fetch-secrets.mjs` to pull Clerk keys from AWS.
# https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# ------------------------------------------------------------------------------
# Required — Clerk authentication
# ------------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-publishable-key
CLERK_SECRET_KEY=sk_test_your-secret-key

# ------------------------------------------------------------------------------
# Required — API backend
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# ------------------------------------------------------------------------------
# Optional — Webhook verification (only needed if running Clerk webhooks locally)
# ------------------------------------------------------------------------------
# CLERK_WEBHOOK_SECRET=whsec_your-webhook-secret

# ------------------------------------------------------------------------------
# Optional — Clerk routing (defaults shown)
# ------------------------------------------------------------------------------
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
# NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/profile
# NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/profile
