{
    "expo": {
        "name": "Sous Chef",
        "slug": "sous-chef-mobile",
        "version": "1.0.0",
        "orientation": "portrait",
        "icon": "./src/assets/icon.png",
        "scheme": "souschef",
        "userInterfaceStyle": "automatic",
        "splash": {
            "image": "./src/assets/splash.png",
            "resizeMode": "contain",
            "backgroundColor": "#ffffff"
        },
        "ios": {
            "supportsTablet": true,
            "bundleIdentifier": "io.souschef.mobile",
            "infoPlist": {
                "CFBundleURLTypes": [
                    {
                        "CFBundleURLSchemes": ["souschef", "io.souschef.mobile"]
                    }
                ]
            }
        },
        "android": {
            "package": "io.souschef.mobile",
            "adaptiveIcon": {
                "foregroundImage": "./src/assets/adaptive-icon.png",
                "backgroundColor": "#ffffff"
            },
            "packageCredentials": []
        },
        "web": {
            "bundler": "metro",
            "favicon": "./src/assets/favicon.png"
        },
        "plugins": [],
        "experiments": {
            "typedRoutes": true
        }
    }
}
