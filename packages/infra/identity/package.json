{
    "name": "@kitchensink/identity-infra",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "synth": "cdk synth --app \"npx tsx bin/app.ts\"",
        "synth:quiet": "cdk synth --quiet --app \"npx tsx bin/app.ts\"",
        "build": "tsc -p tsconfig.json",
        "deploy:cdk": "cdk deploy --all",
        "deploy:sls": "serverless deploy --config serverless.yml",
        "print:sls": "serverless print --config serverless.yml",
        "local:up": "docker compose up -d",
        "local:down": "docker compose down -v",
        "local:wait:localstack": "node ./scripts/wait-for-localstack.mjs",
        "local:wait:postgres": "bash ./scripts/wait-for-postgres.sh",
        "local:init": "bash ./scripts/bootstrap-local.sh",
        "local:invoke": "serverless invoke local --config serverless.yml --stage local",
        "dev:local": "bash ./scripts/dev-local.sh",
        "test": "vitest run",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check ."
    },
    "devDependencies": {
        "@kitchensink/eslint": "*",
        "@kitchensink/prettier": "*",
        "@kitchensink/typescript": "*",
        "@kitchensink/vitest": "*",
        "@types/node": "^24.0.0",
        "aws-cdk": "^2.1010.0",
        "aws-cdk-lib": "^2.220.0",
        "constructs": "^10.4.2",
        "eslint": "^10.0.3",
        "prettier": "^3.0.0",
        "serverless": "^4.0.0",
        "serverless-esbuild": "^1.55.1",
        "serverless-localstack": "^1.3.1",
        "tsx": "^4.20.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "vitest": "^4.0.0"
    }
}
