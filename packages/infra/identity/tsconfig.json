{
    "$schema": "https://json.schemastore.org/tsconfig",
    "extends": "@kitchensink/typescript/base.json",
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "outDir": "dist",
        "rootDir": "."
    },
    "include": ["bin/**/*.ts", "lib/**/*.ts", "src/**/*.ts", "src/**/*.d.ts"],
    "exclude": ["node_modules", "dist"]
}
