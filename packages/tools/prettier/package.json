{
  "name": "@kitchensink/prettier",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./index.json",
    "./*": "./*.json"
  },
  "peerDependencies": {
    "prettier": "^3.0.0"
