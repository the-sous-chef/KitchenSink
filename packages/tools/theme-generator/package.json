{
    "name": "@kitchensink/theme-generator",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "exports": {
        ".": {
            "types": "./src/types.d.ts",
            "default": "./src/index.js"
        },
        "./*": {
            "types": "./src/*.d.ts",
            "default": "./src/*.js"
        },
        "./generate": "./src/generate.js"
    },
    "bin": {
        "generate-theme": "./src/generate.js"
    },
    "scripts": {
        "generate:theme": "node --import=tsx src/generate.js",
        "test": "vitest run --passWithNoTests",
        "typecheck": "tsc --noEmit"
    },
    "devDependencies": {
        "@kitchensink/typescript": "*",
        "@kitchensink/vitest": "*",
        "vitest": "^4.0.0"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,html,yaml,yml}": "prettier --write"
    }
}
