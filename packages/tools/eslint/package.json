{
    "name": "@kitchensink/eslint",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "exports": {
        ".": "./index.js",
        "./*": "./*.js"
    },
    "peerDependencies": {
        "@eslint/js": "^10.0.0",
        "eslint": "^10.0.3",
        "eslint-plugin-import-x": "^4.0.0",
        "typescript-eslint": "^8.56.0"
    },
    "lint-staged": {
        "*.{ts,tsx,js,jsx,mjs,cjs,json,md,css,html,yaml,yml}": "prettier --write"
    }
}
