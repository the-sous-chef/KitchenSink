{
    "name": "@kitchensink/ui",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "sideEffects": false,
    "scripts": {
        "build": "tsc && node scripts/generate-theme.mjs",
        "typecheck": "tsc --noEmit",
        "lint": "eslint 'src/**/*.ts'",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "vitest run"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        },
        "./theme.css": "./dist/theme.css",
        "./tokens/*": {
            "types": "./dist/tokens/*.d.ts",
            "import": "./dist/tokens/*.js",
            "default": "./dist/tokens/*.js"
        }
    },
    "devDependencies": {
        "@kitchensink/eslint": "*",
        "@kitchensink/prettier": "*",
        "@kitchensink/typescript": "*",
        "@kitchensink/vitest": "*",
        "eslint": "^10.0.3",
        "prettier": "^3.0.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.0"
    },
    "engines": {
        "node": "24.x"
    }
}
