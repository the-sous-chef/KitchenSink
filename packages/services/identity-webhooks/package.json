{
    "name": "@kitchensink/identity-webhooks",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "infra:build": "tsc -p infra/tsconfig.json",
        "infra:synth": "cdk synth --app 'npx tsx infra/bin/app.ts'",
        "infra:deploy": "cdk deploy --app 'npx tsx infra/bin/app.ts'",
        "test": "vitest run",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "package": "echo 'TODO: replace stub esbuild packaging command with finalized bundling config' && esbuild src/handlers/*.ts --outdir=dist/handlers --platform=node --format=esm",
        "test:e2e": "vitest run --config vitest.e2e.config.ts"
    },
    "devDependencies": {
        "@kitchensink/eslint": "*",
        "@kitchensink/prettier": "*",
        "@kitchensink/typescript": "*",
        "@kitchensink/vitest": "*",
        "@types/aws-lambda": "^8.10.147",
        "@types/express": "^5.0.6",
        "@types/node": "^24.0.0",
        "esbuild": "^0.27.3",
        "eslint": "^10.0.3",
        "msw": "^2.14.6",
        "prettier": "^3.0.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.0",
        "aws-cdk": "*",
        "aws-cdk-lib": "*",
        "constructs": "*",
        "dotenv": "*",
        "tsx": "*"
    },
    "dependencies": {
        "@aws-lambda-powertools/logger": "^2.29.0",
        "@aws-lambda-powertools/metrics": "^2.29.0",
        "@aws-sdk/client-secrets-manager": "^3.935.0",
        "@aws-sdk/client-sqs": "^3.935.0",
        "@clerk/backend": "^1.27.0",
        "@kitchensink/identity-service": "*",
        "@sentry/aws-serverless": "^10.23.0",
        "drizzle-orm": "^0.45.2",
        "jose": "^6.1.0",
        "pg": "^8.16.3",
        "svix": "^1.62.0"
    },
    "engines": {
        "node": "24.x"
    }
}
