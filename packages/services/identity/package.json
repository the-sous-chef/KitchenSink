{
    "name": "@kitchensink/identity-service",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "nest start --watch",
        "build": "nest build",
        "start": "node dist/main.js",
        "test": "vitest run",
        "test:e2e": "vitest run --config vitest.e2e.config.ts",
        "lint": "eslint .",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "db:generate": "drizzle-kit generate --config drizzle.config.ts"
    },
    "dependencies": {
        "@aws-lambda-powertools/logger": "^2.7.0",
        "@aws-sdk/client-sqs": "^3.723.0",
        "@kitchensink/auth-types": "*",
        "@nestjs/common": "^11.0.0",
        "@nestjs/config": "^4.0.0",
        "@nestjs/core": "^11.0.0",
        "@nestjs/platform-express": "^11.0.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "drizzle-orm": "^0.45.2",
        "pg": "^8.13.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@kitchensink/eslint": "*",
        "@kitchensink/prettier": "*",
        "@kitchensink/typescript": "*",
        "@kitchensink/vitest": "*",
        "@nestjs/cli": "^11.0.0",
        "@types/express": "^5.0.6",
        "@types/node": "^24.0.0",
        "@types/pg": "^8.11.0",
        "drizzle-kit": "^0.30.0",
        "eslint": "^10.0.3",
        "prettier": "^3.0.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.0"
    }
}
