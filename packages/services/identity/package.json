{
    "name": "@kitchensink/identity-service",
    "version": "0.0.0",
    "private": true,
    "type": "module",
    "exports": {
        ".": "./src/index.ts",
        "./types": "./src/types/index.ts",
        "./types/*": "./src/types/*.ts",
        "./database/schema": "./src/database/schema/index.ts",
        "./database/dao": "./src/database/dao/index.ts",
        "./database/ulid": "./src/database/ulid.ts"
    },
    "scripts": {
        "dev": "nest start --watch",
        "build": "nest build",
        "infra:build": "tsc -p infra/tsconfig.json",
        "infra:synth": "cdk synth --app 'npx tsx infra/bin/app.ts'",
        "infra:deploy": "cdk deploy --app 'npx tsx infra/bin/app.ts'",
        "start": "node dist/main.js",
        "test": "vitest run",
        "test:e2e": "vitest run --config vitest.e2e.config.ts",
        "lint": "eslint 'src/**/*.ts' --ignore-pattern '**/*.test.ts'",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "docker:prepare": "node docker-prepare.js",
        "docker:build": "docker build -t kitchensink-identity .",
        "docker:push": "aws ecr get-login-password | docker login --username AWS --password-stdin ${ECR_REGISTRY} && docker push ${ECR_REGISTRY}/kitchensink-identity:${IMAGE_TAG}"
    },
    "dependencies": {
        "@aws-lambda-powertools/logger": "^2.7.0",
        "@aws-sdk/client-s3": "^3.723.0",
        "@aws-sdk/client-sqs": "^3.723.0",
        "@aws-sdk/s3-request-presigner": "^3.723.0",
        "@nestjs/common": "^11.0.0",
        "@nestjs/config": "^4.0.0",
        "@nestjs/core": "^11.0.0",
        "@nestjs/platform-express": "^11.0.0",
        "@sentry/nestjs": "^10.57.0",
        "aws-cdk-lib": "*",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.1",
        "constructs": "*",
        "drizzle-orm": "^0.45.2",
        "pg": "^8.13.0",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "ulidx": "^2.4.1",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@kitchensink/eslint": "*",
        "@kitchensink/prettier": "*",
        "@kitchensink/typescript": "*",
        "@kitchensink/vitest": "*",
        "@nestjs/cli": "^11.0.0",
        "@types/express": "^5.0.6",
        "@types/node": "^24.0.0",
        "@types/pg": "^8.11.0",
        "aws-cdk": "*",
        "dotenv": "*",
        "drizzle-kit": "^0.30.0",
        "eslint": "^10.0.3",
        "prettier": "^3.0.0",
        "tsx": "*",
        "typescript": "^5.9.3",
        "vitest": "^4.0.0"
    },
    "engines": {
        "node": "24.x"
    }
}
